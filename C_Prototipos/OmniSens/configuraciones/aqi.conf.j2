server {
    listen 80;
    server_name ispciot.org www.ispciot.org;

    # Opcional: Redirigir a HTTPS si tienes configurado Certbot en la Raspberry Pi
    # return 301 https://$host$request_uri;

    # Enrutamiento para el Backend API
    location /api/ {
        proxy_pass http://aqi_backend:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Enrutamiento para el Frontend Vue (Nginx Multi-stage)
    location / {
        proxy_pass http://aqi_frontend:80;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Logs específicos para OmniSens
    access_log /var/log/nginx/omnisens_access.log;
    error_log /var/log/nginx/omnisens_error.log;
}
